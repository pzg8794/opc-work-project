0    }{\b0\i0\strike0\f2\cf0\fs13\expnd0\expndtw0\kerning0 \u66x\u45x\u54x\u77x\u105x\u110x\u105x\u80x\u114x\u111x}\par {\b0\i0\strike0\f2\cf0\fs13\expnd0\expndtw0\kerning0            }{\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0 \u80x\u68x\u85x\u44x \u101x\u116x\u99x\u46x\u44x \u116x\u111x \u97x\u99x\u99x\u111x\u109x\u109x\u111x\u100x\u97x\u116x\u101x \u101x\u113x\u117x\u105x\u112x\u109x\u101x\u110x\u116x\u115x}\par {\b0\i0\strike0\f2\cf2\fs13\expnd0\expndtw0\kerning0 \u68x\u105x\u115x\u112x\u108x\u97x\u121x \u83x\u121x\u115x\u116x\u101x\u109x}\par {\b0\i0\strike0\f2\cf2\fs13\expnd0\expndtw0\kerning0            }{\b0\i0\strike0\f2\cf0\fs13\expnd0\expndtw0\kerning0 \u52x\u50x\u34x \u76x\u67x\u68x \u84x\u86x \u83x\u101x\u114x\u105x\u101x\u115x \u76x\u68x \u53x\u53x\u48x\u44x }{\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0 \u70x\u117x\u108x\u108x \u72x\u68x \u49x\u50x\u48x\u72x\u122x}\par {\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0            \u76x\u67x\u68x\u44x \u82x\u101x\u102x\u114x\u101x\u115x\u104x \u82x\u97x\u116x\u101x\u49x\u50x\u48x \u72x\u122x\u44x \u73x\u110x\u116x\u101x\u108x\u108x\u105x\u103x\u101x\u110x\u116x \u83x\u101x\u110x\u115x\u111x\u114x\u44x}\par {\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0            \u78x\u101x\u116x\u67x\u97x\u115x\u116x\u8482x \u69x\u110x\u116x\u101x\u114x\u116x\u97x\u105x\u110x\u109x\u101x\u110x\u116x \u65x\u99x\u99x\u101x\u115x\u115x}\par {\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0            \u40x\u66x\u114x\u111x\u97x\u100x\u98x\u97x\u110x\u100x\u41x\u44x \u87x\u105x\u114x\u101x\u108x\u101x\u115x\u115x \u72x\u68x \u82x\u101x\u97x\u100x\u121x\u44x \u87x\u105x\u45x\u70x\u105x}\par {\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0    }{\b0\i0\strike0\f2\cf0\fs13\expnd0\expndtw0\kerning0 \u66x\u45x\u55x\u76x\u71x}\par {\b0\i0\strike0\f2\cf0\fs13\expnd0\expndtw0\kerning0            }{\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0 \u82x\u101x\u97x\u100x\u121x\u44x \u68x\u78x\u76x\u65x \u67x\u101x\u114x\u116x\u105x\u102x\u105x\u101x\u100x\u44x \u80x\u105x\u99x\u116x\u117x\u114x\u101x\u115x\u44x \u77x\u117x\u115x\u105x\u99x \u97x\u110x\u100x}\par {\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0            \u86x\u105x\u100x\u101x\u111x \u118x\u105x\u97x \u85x\u83x\u66x \u50x\u46x\u48x \u43x \u87x\u97x\u108x\u108x \u77x\u111x\u117x\u110x\u116x \u66x\u114x\u97x\u99x\u107x\u101x\u116x}\par {\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0            }{\b0\i0\strike0\f5\cf0\fs13\expnd0\expndtw0\kerning0 \u40x\u78x\u111x\u116x\u101x\u58x \u109x\u111x\u100x\u101x\u108x \u38x \u112x\u114x\u105x\u99x\u101x \u109x\u97x\u121x \u118x\u97x\u114x\u121x \u100x\u101x\u112x\u101x\u110x\u100x\u115x \u111x\u110x}\par {\b0\i0\strike0\f5\cf0\fs13\expnd0\expndtw0\kerning0            \u97x\u118x\u97x\u105x\u108x\u97x\u98x\u105x\u108x\u105x\u116x\u121x \u117x\u112x\u111x\u110x \u111x\u114x\u100x\u101x\u114x \u99x\u111x\u110x\u102x\u105x\u114x\u109x\u97x\u116x\u105x\u111x\u110x\u41x}\par {\b0\i0\strike0\f5\cf0\fs13\expnd0\expndtw0\kerning0    }{\b0\i0\strike0\f2\cf0\fs13\expnd0\expndtw0\kerning0 \u66x\u45x\u56x}{\b0\i0\strike0\f3\cf0\fs13\expnd0\expndtw0\kerning0 \u67x\u101x\u105x\u108x\u105x\u110x\u103x \u77x\u111x\u117x\u110x\u116x \u66x\u114x\u97x\u99x\u107x\u101x\u116x}{\b0\i0\strike0\f2\cf0\fs13\expnd0\expndtw0\kerning0 \u86x\u97x\u114x\u105x\u111x\u117x\u115x}\par {\b0\i0\strike0\f2\cf0\fs13\expnd0\expndtw0\kerning0            }{\b0\i0\strike0\f2\cf1\fs13\expnd0\expndtw0\kerning0 \u66x\u117x\u105x\u108x\u100x\u105x\u110x\u103x \u50x \u45x \u70x\u105x\u114x\u115x\u116x \u70x\u108x\u111x\u111x\u114x \u91x \u84x\u114x\u97x\u105x\u110x\u105x\u110x\u103x \u38x \u77x\u101x\u101x\u116x\u105x\u110x\u103x \u82x\u111x\u111x\u109x\u115x \u93x\u67x}\par {\b0\i0\strike0\f2\cf2\fs13\expnd0\expndtw0\kerning0 \u67x\u111x\u110x\u116x\u114x\u111x\u108x \u82x\u111x\u111x\u109x \u69x\u113x\u117x\u105x\u112x\u109x\u101x\u110x\u116x}\par {\b0\i0\strike0\f2\cf2\fs13\expnd0\expn