\sectd \pgwsxn15667\pghsxn24388\linex0 {\pard \qj\phpg\pvpg\posx2457\posy549\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch LEARN TO SURF LA - RELEASE OF LIABILITY, WAIVER, AND ASSUMPTION OF RISK AGREEMENT}\b0\par}{\pard \qj\phpg\pvpg\posx1253\posy832\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch CAUTION: DO NOT SIGN THIS DOCUMENT WITHOUT READING IT IN ITS ENTIRETY AND CAREFULLY.  BY SIGNING THIS}\b0\par}{\pard \qj\phpg\pvpg\posx946\posy1088\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch DOCUMENT, YOU GIVE UP IMPORTANT LEGAL RIGHTS! SURFING IS AN ATHLETIC ACTIVITY, THE PARTICIPATION IN WHICH}\b0\par}{\pard \qj\phpg\pvpg\posx3353\posy1344\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch INVOLVES VARIOUS RISKS. PLEASE READ AND UNDERSTAND THIS DOCUMENT.}\b0\par}{\pard \qj\phpg\pvpg\posx741\posy1637\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs20\expnd5\expndtw-1\kerning0\loch THIS IS A LEGAL DOCUMENT. MY SIGNATURE IS MY ACKNOWLEDGMENT OF THE CONTENTS OF THIS CONTRACT. I WILL NOT SIGN}\par}{\pard \qj\phpg\pvpg\posx741\posy1893\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs20\expnd5\expndtw-1\kerning0\loch THIS DOCUMENT UNLESS I FULLY UNDERSTAND AND AGREE TO BE BOUND BY ITS CONTENTS.}\par}{\pard \qj\phpg\pvpg\posx768\posy2112\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch I, ___________________________________, being an adult, (or a minor on whose behalf a parent or legal guardian is signing this}\par}{\pard \qj\phpg\pvpg\posx768\posy2393\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch document) (hereafter “I” or “me”), acknowledge that:}\par}{\pard \qj\phpg\pvpg\posx768\posy2649\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch 1)}\par}{\pard \qj\phpg\pvpg\posx1228\posy2649\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch I Know How To Swim And To Maintain Buoyancy In Open Water, And I Am In Good Health}\b0\par}{\pard \qj\phpg\pvpg\posx11033\posy2649\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch :  My swimming skills are above those}\par}{\pard \qj\phpg\pvpg\posx768\posy2905\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch of a novice and I can maintain my head above water when my feet do not make contact with the bottom for extended periods of time.}\par}{\pard \qj\phpg\pvpg\posx768\posy3186\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Like wise, I am in good physical and mental health, I am not under the influence of any drugs, alcohol, or other substances which may impair}\par}{\pard \qj\phpg\pvpg\posx768\posy3442\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch my swimming skills or my ability to take and follow instructions.  I am not pregnant nor am I suffering from any spinal or skeletal defect,}\par}{\pard \qj\phpg\pvpg\posx768\posy3698\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch hearing, vision or balance impairment or other physical impairment.  I understand that the foregoing representations as to my physical}\par}{\pard \qj\phpg\pvpg\posx768\posy3980\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch cond ition are being relied upon by Learn to Surf LA.  I hereby agree to follow all rules, regulations, and instructions of Learn to surf LA while}\par}{\pard \qj\phpg\pvpg\posx768\posy4236\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch participatin g in this class, lesson, or while renting equipment from Learn to Surf LA.}\par}{\pard \qj\phpg\pvpg\posx768\posy4492\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch 2)}\par}{\pard \qj\phpg\pvpg\posx1228\posy4492\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch I Acknow ledge That Surfing May Be Dangerous And I Accept And Assume Such Risk}\b0\par}{\pard \qj\phpg\pvpg\posx10521\posy4492\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch :  I am aware that open water activities in}\par}{\pard \qj\phpg\pvpg\posx768\posy4773\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch general, and surfing specifically, i nvolves inherent risks.  I may damage my belongings, get hurt, get injured, become ill, drown, or even die.}\par}{\pard \qj\phpg\pvpg\posx768\posy5029\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch I further ackno wledge that I have voluntarily chosen to rent equipment or take surfing lessons from Learn to Surf LA, or if the individual}\par}{\pard \qj\phpg\pvpg\posx768\posy5312\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch taking such lessons or renting equipment is a minor, I have, as the minor’s parent or legal guardian, voluntarily consented to such minor}\par}{\pard \qj\phpg\pvpg\posx768\posy5568\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch taking of such lessons, or renting equipment.  I know and fully understand that water sports and surfing is a dangerous outdoor activity in an}\par}{\pard \qj\phpg\pvpg\posx768\posy5824\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch unco ntrolled n atural e nvironment with inherent risks and hazards, where serious accidents can occur, participants can sustain property}\par}{\pard \qj\phpg\pvpg\posx768\posy6105\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch dama ge, inj uri es, illness and even die.  I acknowledge and willingly and voluntarily assume all risks and hazards in surfing and beach}\par}{\pard \qj\phpg\pvpg\posx768\posy6361\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch relate d activities in all phases of these activities from the training sessions until the conclusion of the class, lesson, or equipment rental}\par}{\pard \qj\phpg\pvpg\posx768\posy6617\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch period, including, but not limited to those involving, (1) loss of control of the surfboard, malfunction of the surfboard, falls from the surfboard,}\par}{\pard \qj\phpg\pvpg\posx768\posy6898\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch collision with other participants, equipment, other surfboards, rocks, and any  other man made or natural obstacles, whether obvious or not;}\par}{\pard \qj\phpg\pvpg\posx768\posy7154\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch (2) jud gment, decision making and conduct of the instructors; (3) submersion in water, drowning; (4) encounters with animals, marine life,}\par}{\pard \qj\phpg\pvpg\posx768\posy7410\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch plant life, rocks and insects; (5) exposur e to outdoor ocean environment, bacteria or microbes, extreme temperatures, sun, and inclement}\par}{\pard \qj\phpg\pvpg\posx768\posy7692\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch weather, including travel by foot or vehicle in an y way related to this activity; (6) assistance in lifting and /or carrying surfing equipment; (7)}\par}{\pard \qj\phpg\pvpg\posx768\posy7948\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch rescue-related injuries; and (8) unavailability of immedi ate and appropriate medical attention in case of injury.  I understand and}\par}{\pard \qj\phpg\pvpg\posx768\posy8204\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch acknowledg e that the above list is not meant to be complete or exhaustive, and that other unforeseen and unanticipated risks, known or}\par}{\pard \qj\phpg\pvpg\posx768\posy8485\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch unkn own, may also exist and result in damage, injury, illness, disease, or death.}\par}{\pard \qj\phpg\pvpg\posx768\posy8741\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch 3)}\par}{\pard \qj\phpg\pvpg\posx1228\posy8741\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch I Waive My Right To Sue Learn To Surf LA}\b0\par}{\pard \qj\phpg\pvpg\posx5810\posy8741\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch :  In consideration for Learn to Surf LA agreeing to provide me with equipment rental or}\par}{\pard \qj\phpg\pvpg\posx768\posy8997\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch surfing instructions and/or allo wing me to participate in this class or lesson, I agree that I shall not make a claim or bring any action against,}\par}{\pard \qj\phpg\pvpg\posx768\posy9280\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch sue, or hold responsible, the City of Santa Monica, Learn to Surf LA, its owners (including Patrick Murphy), officers, agents, employees,}\par}{\pard \qj\phpg\pvpg\posx768\posy9536\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch associ ates, representatives, (referred to collectively in this agreement as “}\par}{\pard \qj\phpg\pvpg\posx8293\posy9536\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Learn to Surf LA}\b0\par}{\pard \qj\phpg\pvpg\posx10085\posy9536\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch ”) or expect, require, or pursue them, to be held}\par}{\pard \qj\phpg\pvpg\posx768\posy9792\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch accountable fo r any dama ges.  I voluntarily agree to release, discharge, and hold harmless Learn to Surf LA from and against any and all}\par}{\pard \qj\phpg\pvpg\posx768\posy10073\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch claims of liability, even those arising out of their negligence, fault, recklessness, or any other act or omission which causes me damages,}\par}{\pard \qj\phpg\pvpg\posx768\posy10329\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch illness, injury, disease, or death, of any nature in any way connected with my participation in this activity.  I also expressly agree to release}\par}{\pard \qj\phpg\pvpg\posx768\posy10585\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch and discharge Learn to Surf LA from any act or omission, excluding acts of wanton or gross negligence, in rendering or failing to render any}\par}{\pard \qj\phpg\pvpg\posx768\posy10866\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch type of rescue, emergency or medical services.}\par}{\pard \qj\phpg\pvpg\posx768\posy11122\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch 4)}\par}{\pard \qj\phpg\pvpg\posx1228\posy11122\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Indemnity}\b0\par}{\pard \qj\phpg\pvpg\posx2304\posy11122\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch :  I further agree, to hold harmless, defend, and indemnify Learn to Surf LA and the City of Santa Monica from all defense}\par}{\pard \qj\phpg\pvpg\posx768\posy11404\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch costs, includin g attorney’s fees incurr ed in connection with any claims arising from the activities anticipated herein, including but not limited}\par}{\pard \qj\phpg\pvpg\posx768\posy11660\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch to those for bo dily in jury, wro ngful death, or property damage, whether caused by or sustained by any minor under 18 years of age on}\par}{\pard \qj\phpg\pvpg\posx768\posy11916\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch whose behalf I am signing, or which I may have caused to spectators or other third parties, whether negligent or not, in the course of my}\par}{\pard \qj\phpg\pvpg\posx768\posy12197\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch participation in this activity.  In the event of any actions, regardless of where venue lies, any such actions shall be filed in the State Court of}\par}{\pard \qj\phpg\pvpg\posx768\posy12453\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Los Angeles County, California.  In the event that any action is filed other than in the State Court of Los Angeles County, California, it shall}\par}{\pard \qj\phpg\pvpg\posx768\posy12709\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch be move d to State Court of Los Angeles County, California on motion and at the option of Learn to Surf LA.}\par}{\pard \qj\phpg\pvpg\posx768\posy12992\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch 5)}\par}{\pard \qj\phpg\pvpg\posx1228\posy12992\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Permission to Obtain Medical Assistance}\b0\par}{\pard \qj\phpg\pvpg\posx5733\posy12992\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch :  In the event of any injury, illness, emergency, accident or other harm sustained by me (or}\par}{\pard \qj\phpg\pvpg\posx768\posy13248\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch by the minor on whose behalf I am signing this document), I hereby give Learn to Surf LA permission to obtain Medical Assistance, in which}\par}{\pard \qj\phpg\pvpg\posx768\posy13504\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch event I hereby make the same releases and waivers in Learn to Surf LA’s favor as I have otherwise made in this agreement in connection}\par}{\pard \qj\phpg\pvpg\posx768\posy13785\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch with an y such medical assistance sought or not sought.  In addition, the expenses for any such medical emergency shall be my sole}\par}{\pard \qj\phpg\pvpg\posx768\posy14041\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch respo nsibility and not that of Learn to Surf LA.}\par}{\pard \qj\phpg\pvpg\posx768\posy14297\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch 6)}\par}{\pard \qj\phpg\pvpg\posx1228\posy14297\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Promotional Use of Images}\b0\par}{\pard \qj\phpg\pvpg\posx4197\posy14297\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch :  I hereby agree that Learn to Surf LA may use film or photographic records of this surfing class or lesson}\par}{\pard \qj\phpg\pvpg\posx768\posy14578\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch for its promotional and/or commercial purposes without compensation to me, and I consent to the use of my name and likeness for such use}\par}{\pard \qj\phpg\pvpg\posx768\posy14834\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch in an y media now known or not known.}\par}{\pard \qj\phpg\pvpg\posx741\posy15141\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch 7)}\par}{\pard \qj\phpg\pvpg\posx1202\posy15141\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch I HAVE READ THIS DOCUMENT IN ITS ENTIRETY AND IT IS MY INTENTION THAT IT BE BROADLY CONSTRUED IN FAVOR OF LEARN TO}\b0\par}{\pard \qj\phpg\pvpg\posx741\posy15397\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch SURF LA IN THE EVENT OF ANY AMBIGUITIES, WHICH SHALL BE RESOLVED IN LEARN TO SURF LA’S FAVOR.  I UNDERSTAND THAT I AM}\b0\par}{\pard \qj\phpg\pvpg\posx741\posy15628\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch ASSUMING ALL THE RISKS INHERENT IN THIS SURFING ACTIVITY, AND THAT I MAY BE INJURED, BECOME ILL, OR EVEN DIE AS A RESULT OF}\b0\par}{\pard \qj\phpg\pvpg\posx741\posy15858\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch SURFING.  I UNDERSTAND THAT THIS IS A RELEASE OF ANY AND ALL CLAIMS.  I UNDERSTAND THAT THIS IS THE ENTIRE AGREEMENT}\b0\par}{\pard \qj\phpg\pvpg\posx741\posy16089\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch BETWEEN ME AND LEARN TO SURF LA, AND THAT NO REPRESENTATIONS HAVE BEEN MADE TO ME BY LEARN TO SURF LA OUTSIDE OF}\b0\par}{\pard \qj\phpg\pvpg\posx741\posy16320\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch THIS AGREEMENT.  I VOLUNTARILY SIGN MY NAME AS EVIDENCE OF MY ACCEPTANCE OF ALL THE PROVISIONS IN THIS RELEASE AND MY}\b0\par}{\pard \qj\phpg\pvpg\posx741\posy16576\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch AGREEMENT TO BE BOUND BY THEM}\b0\par}{\pard \qj\phpg\pvpg\posx4505\posy16576\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs17\expnd5\expndtw-1\kerning0\loch .}\par}{\pard \qj\phpg\pvpg\posx768\posy17010\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Name of participant___________________________________________________________________________________________}\par}{\pard \qj\phpg\pvpg\posx768\posy17548\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Name of par ent/guardian (in case of minor participant)_______________________________ __ ___ ____________________________}\par}{\pard \qj\phpg\pvpg\posx768\posy18085\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Signature__________________________ __ ___ _____ ______________________________________ Date_____________________}\par}{\pard \qj\phpg\pvpg\posx768\posy18597\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch Would you like to receive o ur e-newsletter?  If so, write your email here___________________________ ___ _____________________}\par}{\pard \qj\phpg\pvpg\posx2560\posy18880\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs22\expnd5\expndtw-1\kerning0\loch *If you have already subscribed to our newsletter by another method, please leave this line blank*}\b0\par}{ \sect}}
