\sectd \pgwsxn15667\pghsxn24388\linex0 {\pard \qj\phpg\pvpg\posx4684\posy281\dfrmtxtx0\dfrmtxty0{\b\cf1\f0\fs34\expnd5\expndtw-1\kerning0\loch WAIVER AND RELEASE OF LIABILITY}\b0\par}{\pard \qj\phpg\pvpg\posx665\posy1100\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch In	consideration	of	Ocoee	Inn	Rafting,	Inc.	furnishing	services	and/or	equipment	to	enable	me	to	par-}\par}{\pard \qj\phpg\pvpg\posx665\posy1458\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch ticipate	in	whitewater	rafting	activities,	I	agree	as	follows:}\par}{\pard \qj\phpg\pvpg\posx665\posy2201\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch I	fully	understand	 and	acknowledge	that	(a)	risks	and	dangers	exist	in	my	use	 of	whitewater	rafting}\par}{\pard \qj\phpg\pvpg\posx665\posy2560\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch and	my	participation	in	whitewater	rafting	activities,	and	in	loading	and	unloading	onto	and	being	transported}\par}{\pard \qj\phpg\pvpg\posx665\posy2944\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch to	recreational	sites	by	bus	or	van.	(b)	my	participation	in	such	activities	and/or	use	of	such	equipment	may}\par}{\pard \qj\phpg\pvpg\posx665\posy3301\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch result	in	injury,	or	illness	including,		but	not	limited	to	bodily	injury,	disease,	strains,	fractures,	partial	and/or}\par}{\pard \qj\phpg\pvpg\posx665\posy3660\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch total	paralysis,	death	or	other	ailments	that	could	cause	serious	disability;	(c)	these	risks	and	dangers	may}\par}{\pard \qj\phpg\pvpg\posx640\posy4018\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch be caused by the negligence of the owners, employees, officers or agents of the United States, The Tennes-}\par}{\pard \qj\phpg\pvpg\posx640\posy4402\dfrmtxtx0\dfrmtxty0{\cf1\f0\fs30\expnd5\expndtw-1\kerning0\loch see Valley Authority, the State of 